# Local Netlify folder
.netlify
node_modules/
screenshots/
.DS_Store
*.md~

public/*
# The publish-landing-pages workflow (in the chatbot repo) intentionally
# commits generated SEO landing pages here — keep this one path trackable.
# (git can't re-include a path under an excluded parent directory, so each
# level has to be un-ignored individually rather than negated in one line.)
!public/tools
public/tools/*
!public/tools/rovr
# deploy.sh (chatbot repo) also stages the generated Cloudflare Pages
# redirects file — without this, `git add public/_redirects` fails (ignored
# file, non-fatal warning but nonzero exit) and aborts the deploy under
# set -e before the commit/push/wrangler steps ever run.
!public/_redirects

resources/
.hugo_build.lock
